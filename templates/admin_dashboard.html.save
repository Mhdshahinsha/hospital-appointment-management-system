
<!-- Welcome Section -->

<div class="welcome-container">

    <h1 class="welcome-title">
        Welcome, {{ session.full_name }}
    </h1>

    <p class="welcome-subtitle">
        Administrator Dashboard
    </p>

</div>

<!-- Statistics Cards -->

<div class="container">

    <div class="row">

        <div class="col-md-3">

            <div class="dashboard-card">

                <h4>Total Doctors</h4>

                <h2>15</h2>

            </div>

        </div>

        <div class="col-md-3">

            <div class="dashboard-card">

                <h4>Total Patients</h4>

                <h2>250</h2>

            </div>

        </div>

        <div class="col-md-3">

            <div class="dashboard-card">

                <h4>Appointments</h4>

                <h2>35</h2>

            </div>

        </div>

        <div class="col-md-3">

            <div class="dashboard-card">

                <h4>Revenue</h4>

                <h2>₹45,000</h2>

            </div>

        </div>

    </div>

</div>
<!-- Recent Appointments -->

<div class="container mt-5">

    <div class="dashboard-card">

        <h3 class="mb-4">
            Recent Appointments
        </h3>

        <table class="table table-dark table-hover">

            <thead>

                <tr>

                    <th>Patient</th>

                    <th>Doctor</th>

                    <th>Date</th>

                    <th>Time</th>

                    <th>Status</th>

                </tr>

            </thead>

            <tbody>

                <tr>

                    <td>Rahul</td>

                    <td>Dr. John</td>

                    <td>20-06-2026</td>

                    <td>10:00 AM</td>

                    <td>
                        <span class="badge bg-success">
                            Confirmed
                        </span>
                    </td>

                </tr>

                <tr>

                    <td>Anjali</td>

                    <td>Dr. Smith</td>

                    <td>20-06-2026</td>

                    <td>11:30 AM</td>

                    <td>
                        <span class="badge bg-warning text-dark">
                            Pending
                        </span>
                    </td>

                </tr>

                <tr>

                    <td>Arun</td>

                    <td>Dr. David</td>

                    <td>21-06-2026</td>

                    <td>02:00 PM</td>

                    <td>
                        <span class="badge bg-danger">
                            Cancelled
                        </span>
                    </td>

                </tr>

            </tbody>

        </table>

    </div>

</div>
{% endblock %}
