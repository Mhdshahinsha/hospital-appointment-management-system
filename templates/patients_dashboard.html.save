{% extends "base.html" %}

{% block title %}
Patient Dashboard
{% endblock %}

{% block content %}

<div class="container py-5">

    <!-- Welcome Section -->

    <div class="welcome-container">

        <h1 class="welcome-title">

            Welcome, {{ session.full_name }}

        </h1>

        <p class="welcome-subtitle">

            Patient Dashboard

        </p>

    </div>

    <!-- Statistics -->

    <div class="row g-4 mt-3">

        <div class="col-lg-3 col-md-6">

            <div class="dashboard-card">

                <h5>Appointments</h5>

                <h2>3</h2>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="dashboard-card">

                <h5>Upcoming Visits</h5>

                <h2>1</h2>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="dashboard-card">

                <h5>Medical Records</h5>

                <h2>5</h2>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="dashboard-card">

                <h5>Pending Bills</h5>

                <h2>₹1,500</h2>

            </div>

        </div>

    </div>

    <!-- Appointment Table -->

    <div class="dashboard-card mt-5">

        <h3 class="mb-4">

            My Appointments

        </h3>

        <table class="table table-dark table-hover align-middle">

            <thead>

                <tr>

                    <th>Doctor</th>

                    <th>Date</th>

                    <th>Time</th>

                    <th>Status</th>

                </tr>

            </thead>

            <tbody>

                <tr>

                    <td>Dr. John</td>

                    <td>25-06-2026</td>

                    <td>10:00 AM</td>

                    <td>

                        <span class="badge bg-success">

                            Confirmed

                        </span>

                    </td>

                </tr>

                <tr>

                    <td>Dr. Smith</td>

                    <td>30-06-2026</td>

                    <td>11:30 AM</td>

                    <td>

                        <span class="badge bg-warning text-dark">

                            Pending

                        </span>

                    </td>

                </tr>

            </tbody>

        </table>

    </div>

    <!-- Quick Actions -->

    <div class="mt-5">

        <h3 class="text-white mb-4">

            Quick Actions

        </h3>

        <div class="row g-3">

            <div class="col-md-3">

                <button class="btn btn-login w-100">

                    <i class="bi bi-calendar-plus-fill"></i>

                    Book Appointment

                </button>

            </div>

            <div class="col-md-3">

                <button class="btn btn-login w-100">

                    <i class="bi bi-file-medical-fill"></i>

                    Medical Records

                </button>

            </div>

            <div class="col-md-3">

                <button class="btn btn-login w-100">

                    <i class="bi bi-receipt-cutoff"></i>

                    My Bills

                </button>

            </div>

            <div class="col-md-3">

                <a href="{{ url_for('logout') }}" class="btn btn-login w-100">

                    <i class="bi bi-box-arrow-right"></i>

                    Logout

                </a>

            </div>

        </div>

    </div>

</div>

{% endblock %}o

